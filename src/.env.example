# Copie este arquivo para .env e ajuste os valores:
#   copy .env.example .env      (Windows)
#   cp .env.example .env        (Linux/macOS)
#
# O Docker Compose le automaticamente o .env na pasta src/.
# Sem .env, os valores padrao do docker-compose.yml sao usados (MailHog).

# --- Banco de dados (backend) ---
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/ctrl_fleet
SPRING_DATASOURCE_USERNAME=admin
SPRING_DATASOURCE_PASSWORD=admin

# --- JWT ---
JWT_SECRET=ctrlfleet-dev-secret-key-min-32-chars!!

# --- E-mail: desenvolvimento com MailHog ---
SPRING_MAIL_HOST=mailhog
SPRING_MAIL_PORT=1025
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_SMTP_AUTH=false
SPRING_MAIL_SMTP_STARTTLS=false
CTRLFLEET_MAIL_ENABLED=true
CTRLFLEET_MAIL_FROM=noreply@ctrlfleet.gov.br
CTRLFLEET_MAIL_FROM_NAME=CtrlFleet

# --- E-mail: Brevo (descomente e preencha para envio real) ---
# SPRING_MAIL_HOST=smtp-relay.brevo.com
# SPRING_MAIL_PORT=587
# SPRING_MAIL_USERNAME=123456@smtp-brevo.com
# SPRING_MAIL_PASSWORD=xsmtpsib-sua-chave-smtp
# SPRING_MAIL_SMTP_AUTH=true
# SPRING_MAIL_SMTP_STARTTLS=true
# CTRLFLEET_MAIL_FROM=seu-email-verificado@exemplo.com
